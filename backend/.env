# ============================================================
# backend/.env.example — Copiar como .env y completar valores
# ============================================================

# Servidor
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# PostgreSQL + PostGIS
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medellin_electoral
DB_USER=postgres
DB_PASSWORD=1234

# Geocodificación (Nominatim no requiere API key, pero puedes usar Google Maps)
# GOOGLE_MAPS_API_KEY=tu_api_key_aqui

# JWT (para autenticación futura)
# JWT_SECRET=tu_secreto_jwt_aqui
